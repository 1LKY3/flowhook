<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fh_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Brand header -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_launcher_fg"
                android:background="#0B0D10"
                android:padding="4dp"
                android:contentDescription="Flowhook"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Flowhook"
                android:textColor="@color/fh_fg"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  Android only bitch™"
                android:textColor="@color/fh_muted"
                android:textSize="10sp"/>
        </LinearLayout>

        <!-- Status card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STATUS"
                android:textColor="@color/fh_accent"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Initializing..."
                android:textColor="@color/fh_fg"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="3dp"/>
        </LinearLayout>

        <!-- Config card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONNECTION"
                android:textColor="@color/fh_accent"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Server URL"
                android:textColor="@color/fh_muted"
                android:textSize="11sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/server"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_edit"
                android:padding="10dp"
                android:textColor="@color/fh_fg"
                android:textColorHint="@color/fh_muted"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:inputType="textUri"
                android:importantForAutofill="no"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agent token"
                android:textColor="@color/fh_muted"
                android:textSize="11sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_edit"
                android:padding="10dp"
                android:textColor="@color/fh_fg"
                android:textColorHint="@color/fh_muted"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:inputType="textVisiblePassword"
                android:importantForAutofill="no"
                android:singleLine="false"
                android:maxLines="4"/>
        </LinearLayout>

        <!-- Primary action -->
        <android.widget.Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Save &amp; (re)start service"
            android:textColor="#0B0D10"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:background="@drawable/bg_button_primary"
            android:stateListAnimator="@null"
            android:layout_marginBottom="12dp"/>

        <!-- Permission row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <android.widget.Button
                android:id="@+id/btn_adb"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Connect ADB"
                android:textColor="@color/fh_fg"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:background="@drawable/bg_button_ghost"
                android:stateListAnimator="@null"/>

            <android.widget.Button
                android:id="@+id/btn_test"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Test shell"
                android:textColor="@color/fh_fg"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:background="@drawable/bg_button_ghost"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <!-- Battery/system section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KEEP ALIVE"
            android:textColor="@color/fh_accent"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Samsung aggressively kills background apps. Grant all three:"
            android:textColor="@color/fh_muted"
            android:textSize="12sp"
            android:layout_marginBottom="12dp"/>

        <android.widget.Button
            android:id="@+id/btn_battery_opt"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="1. Ignore battery optimization"
            android:textColor="@color/fh_fg"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:background="@drawable/bg_button_ghost"
            android:stateListAnimator="@null"
            android:layout_marginBottom="8dp"/>

        <android.widget.Button
            android:id="@+id/btn_samsung"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="2. Samsung: Never sleeping apps"
            android:textColor="@color/fh_fg"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:background="@drawable/bg_button_ghost"
            android:stateListAnimator="@null"
            android:layout_marginBottom="8dp"/>

        <android.widget.Button
            android:id="@+id/btn_app_info"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="3. App info (Unrestricted background)"
            android:textColor="@color/fh_fg"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:background="@drawable/bg_button_ghost"
            android:stateListAnimator="@null"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="v0.1.3"
            android:textColor="@color/fh_muted"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:layout_marginTop="8dp"/>
    </LinearLayout>
</ScrollView>
