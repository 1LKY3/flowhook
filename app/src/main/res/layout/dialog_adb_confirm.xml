<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/fh_card"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Turn off ADB Bridge?"
        android:textColor="@color/fh_fg"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This cuts normal remote command execution by stopping the local ADB connector. Use Recover ADB Bridge or turn this switch back on to restore it; USB is only needed if Android has cleared every local ADB listener."
        android:textColor="@color/fh_fg"
        android:textSize="14sp"
        android:lineSpacingExtra="3dp"
        android:layout_marginBottom="20dp"/>

    <android.widget.Button
        android:id="@+id/btn_cancel"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Leave ADB Bridge on"
        android:textColor="#0B0D10"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textStyle="bold"
        android:background="@drawable/bg_button_primary"
        android:stateListAnimator="@null"
        android:layout_marginBottom="10dp"/>

    <android.widget.Button
        android:id="@+id/btn_confirm"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Turn ADB Bridge off"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textStyle="bold"
        android:background="@drawable/bg_button_danger"
        android:stateListAnimator="@null"/>
</LinearLayout>
